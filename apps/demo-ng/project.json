{
  "name": "demo-ng",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/demo-ng/src",
  "prefix": "app",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "browser": "apps/demo-ng/src/main.ts",
        "tsConfig": "apps/demo-ng/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/demo-ng/public"
          }
        ],
        "styles": ["apps/demo-ng/src/styles.css"],
        "outputPath": "dist/demo-ng"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/demo-ng/src/environments/environment.ts",
              "with": "apps/demo-ng/src/environments/environment.development.ts"
            }
          ]
        },
        "demo": {
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/demo-ng/src/environments/environment.ts",
              "with": "apps/demo-ng/src/environments/environment.demo.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production",
      "outputs": ["{options.outputPath}"]
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "demo-ng:build:production"
        },
        "development": {
          "buildTarget": "demo-ng:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:unit-test"
    }
  }
}
